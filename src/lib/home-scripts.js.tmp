
/* ==========================================================
   MIA COMPRA · landing
   >>> EDITA SOLO ESTA LÍNEA: pon el número de WhatsApp real
   formato internacional sin signos: 1 + número (EE.UU) por ej. 13055551234
   ========================================================== */
const WA_NUMBER = "1XXXXXXXXXX"; // [A COMPLETAR: número real de WhatsApp]

(function wireWA(){
  document.querySelectorAll('[data-wa]').forEach(el=>{
    const msg = el.getAttribute('data-msg') || 'Hola Mia Compra';
    el.setAttribute('href', `https://wa.me/${WA_NUMBER}?text=${encodeURIComponent(msg)}`);
    el.setAttribute('target','_blank'); el.setAttribute('rel','noopener');
  });
})();

const reduce = matchMedia('(prefers-reduced-motion: reduce)').matches;

/* Nav scrolled */
const nav = document.getElementById('nav');
addEventListener('scroll',()=>nav.classList.toggle('scrolled',scrollY>40),{passive:true});

/* Burger */
const burger=document.getElementById('burger'), links=document.querySelector('.nav-links');
burger.addEventListener('click',()=>{
  const open=links.style.display==='flex';
  Object.assign(links.style, open?{display:''}:{display:'flex',position:'absolute',top:'118%',right:'1rem',flexDirection:'column',background:'rgba(6,16,44,.96)',backdropFilter:'blur(16px)',padding:'1.3rem 1.7rem',borderRadius:'18px',gap:'1rem',border:'1px solid rgba(255,255,255,.12)'});
});
links.querySelectorAll('a').forEach(a=>a.addEventListener('click',()=>links.style.display=''));

/* Reveal */
const io=new IntersectionObserver(es=>es.forEach(e=>{
  if(e.isIntersecting){e.target.classList.add('in');io.unobserve(e.target);}
}),{threshold:.08});
document.querySelectorAll('.rv').forEach(el=>io.observe(el));
setTimeout(()=>document.querySelectorAll('.rv:not(.in)').forEach(el=>{
  if(el.getBoundingClientRect().top<innerHeight) el.classList.add('in');
}),3500);

/* Step nodes activate + roadmap fill */
const steps=[...document.querySelectorAll('.step')];
const sio=new IntersectionObserver(es=>es.forEach(e=>{if(e.isIntersecting)e.target.classList.add('in');}),{threshold:.5});
steps.forEach(s=>sio.observe(s));
(function roadFill(){
  if(reduce)return;
  const road=document.getElementById('road'), fill=document.getElementById('roadFill');
  if(!road||!fill)return;
  function upd(){
    const r=road.getBoundingClientRect();
    const start=r.top-innerHeight*.6, end=r.bottom-innerHeight*.5, total=end-start;
    const p=Math.max(0,Math.min(1,(0-start)/total));
    fill.style.transform=`scaleY(${p})`;
  }
  addEventListener('scroll',upd,{passive:true}); addEventListener('resize',upd); upd();
})();

/* FAQ */
document.querySelectorAll('.faq-item').forEach(item=>{
  const q=item.querySelector('.faq-q'), a=item.querySelector('.faq-a');
  q.addEventListener('click',()=>{
    const open=item.classList.contains('open');
    document.querySelectorAll('.faq-item.open').forEach(i=>{i.classList.remove('open');i.querySelector('.faq-a').style.maxHeight='0';});
    if(!open){item.classList.add('open');a.style.maxHeight=a.scrollHeight+'px';}
  });
});

/* Magnetic buttons */
(function(){
  if(reduce)return;
  document.querySelectorAll('.shimmer-btn-wrapper,.btn-glass').forEach(btn=>{
    btn.addEventListener('mousemove',e=>{const r=btn.getBoundingClientRect();const x=(e.clientX-r.left-r.width/2)/r.width;const y=(e.clientY-r.top-r.height/2)/r.height;btn.style.transform=`translate(${x*9}px,${y*9}px)`;});
    btn.addEventListener('mouseleave',()=>btn.style.transform='');
  });
})();

/* Marquees: duplicate tracks for seamless loop */
(function(){
  ['marqTrack','tstTrack','chipA','chipB'].forEach(id=>{const t=document.getElementById(id);if(t)t.innerHTML+=t.innerHTML;});
})();

/* Parallax bg + iOS fallback (bg-attachment:fixed bugs on iOS) */
(function(){
  const bg=document.getElementById('paraBg');
  if(bg) bg.style.backgroundImage="url('assets/para-familia.jpg')";
  const isIOS=/iPad|iPhone|iPod/.test(navigator.userAgent)||(navigator.platform==='MacIntel'&&navigator.maxTouchPoints>1);
  if(isIOS){
    document.querySelectorAll('.para-bg,.hero-bg-img').forEach(el=>el.style.backgroundAttachment='scroll');
  }
})();
